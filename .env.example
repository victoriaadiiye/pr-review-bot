SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
WATCHED_CHANNEL_ID=your-private-channel-id
NOTIFY_USER_ID=U0AAA401YTT

# Optional: extra questions Claude should answer about each PR
# REVIEW_QUESTIONS="Does this follow our error handling patterns?\nAre there any missing tests?"

